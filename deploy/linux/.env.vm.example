# Core strategy flags
USE_TESTNET=True
USE_AGGRESSIVE_TRADING=True
ALLOW_GAMMA_OVERRIDE=True
GAMMA_PRICE_BUFFER=10

# Broker/API credentials (fill in before running)
HL_SECRET_KEY=
HL_TESTNET_SECRET_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_TRADE=True

# Scanner / selector
SCANNER_ENABLED=true
SCANNER_TOP_N=5
SCANNER_UNIVERSE=BTC,ETH,SOL,XRP,DOGE,AVAX,LINK,ADA

# Agent selector (optional)
USE_AGENT_SELECTOR=false
OPENAI_API_KEY=
AGENT_MODEL=gpt-5-mini
AGENT_TIMEOUT_SECONDS=8
AGENT_CONFIDENCE_MIN=0.65

# Safety filters
MIN_SCANNER_SCORE=0.0
MIN_DOLLAR_VOLUME=10000
MIN_VOLATILITY=0.00005
MAX_VOLATILITY=0.02
ALLOW_SYMBOL_SWITCH_WHILE_OPEN_POSITION=false
SUPPORTED_COINS_ALPACA=BTC,ETH,SOL,XRP,DOGE,AVAX,LINK,ADA
SUPPORTED_COINS_HYPERLIQUID=BTC,ETH,SOL,XRP,DOGE,AVAX,LINK,ADA
